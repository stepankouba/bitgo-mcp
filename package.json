{
  "name": "bitgo-mcp",
  "version": "0.1.0",
  "description": "BitGo MCP server for Littlebit custody wallet monitoring",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --out-dir dist",
